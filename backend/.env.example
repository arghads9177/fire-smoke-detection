# Copy to .env and adjust. Loaded by app/config.py via pydantic-settings.

# MongoDB replica set: comma-separated host:port members (or a single host).
# Leave MONGO_REPLICA_SET/MONGO_USER/MONGO_PASSWORD empty for a local unauthenticated mongod.
MONGO_HOSTS=rs1.sisx.in:27001,rs2.sisx.in:27001,rs3.sisx.in:27000
MONGO_REPLICA_SET=rssisx
MONGO_DB=videoAnalyticDB
MONGO_USER=viadmin
# Quote the password if it contains '#' (dotenv comment character)
MONGO_PASSWORD="changeme"
# Database the user is defined on; defaults to MONGO_DB when empty
MONGO_AUTH_SOURCE=

# API key the AI service must send on /detections and /heartbeat (X-API-Key header)
API_KEY=changeme

# Dashboard origin for CORS
CORS_ORIGIN=http://localhost:4200

# Directory of annotated snapshots, served statically at /snapshots/*
SNAPSHOTS_DIR=snapshots
